# ===========================
# Server
# ===========================
PORT=3000
NODE_ENV=development

# ===========================
# Security & CORS
# ===========================
JWT_SECRET=                          # min 32 karakter random
CORS_ORIGINS=http://localhost:4321   # pisah koma jika >1: http://a.com,http://b.com
COOKIE_SECURE=false                  # true di production (HTTPS)
COOKIE_SAMESITE=lax
COOKIE_HTTP_ONLY=true                # ← tambahkan, penting untuk XSS protection

# ===========================
# JWT Auth
# ===========================
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=7
JWT_REFRESH_REMEMBER_ME_EXPIRES_DAYS=30
JWT_REMEMBER_ME_EXPIRES=14d
JWT_REFRESH_SECRET=                  # ← tambahkan, BERBEDA dari JWT_SECRET

# ===========================
# Database
# ===========================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=                   # ← tambahkan, untuk operasi public/anon
REDIS_URL=redis://localhost:6379

# ===========================
# Apps Script (Sheets)
# ===========================
APPS_SCRIPT_URL_BELANJA_BULANAN=
APPS_SCRIPT_URL_INVENTORY_KENDARAAN=
APPS_SCRIPT_API_KEY_BELANJA_BULANAN=
APPS_SCRIPT_API_KEY_INVENTORY_KENDARAAN=
APPS_SCRIPT_URL_KEY_AUTH=
APPS_SCRIPT_API_KEY_AUTH=

# ===========================
# Email / SMTP
# ===========================
LOG_LEVEL=debug                      # ← pindahkan ke section Logging sendiri
EMAIL_PROVIDER=mailtrap
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com     # ← tambahkan, dipakai di email "From:"

# ===========================
# Logging
# ===========================
LOG_LEVEL=debug