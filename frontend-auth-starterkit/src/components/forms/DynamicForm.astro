---
// DynamicForm.astro
// Requires: Select2Provider.astro loaded once in Layout.astro
import FormField from "./FormField.astro";

interface Props {
  formId: string;
  fields: any[];
  submitLabel?: string;
  layout?: "single" | "footer" | "none";
  submitId?: string;
  submitIcon?: string;
}

const {
  formId,
  fields,
  submitLabel = "Submit",
  layout = "single",
  submitId = "submitBtn",
  submitIcon = "",
} = Astro.props;
---

<form
  id={formId}
  enctype="multipart/form-data"
  class="space-y-4"
  autocomplete="off"
>
  {fields.map((field) => (
    <FormField {...field} />
  ))}

  {layout === "single" && (
    <button
      type="submit"
      id={submitId}
      class="w-full mt-6 bg-blue-700 text-white shadow-md font-medium px-4 py-2 rounded-md hover:bg-blue-800 transition-all"
    >
      {submitIcon && <i class={submitIcon} />} {submitLabel}
    </button>
  )}

  {layout === "footer" && (
    <div class="flex items-center justify-end gap-3 mt-8 pt-4 border-t border-gray-100">
      <button
        type="button"
        class="px-4 py-2 text-sm font-semibold bg-gray-100 border border-gray-300 hover:bg-gray-200 rounded-md"
      >
        Cancel
      </button>
      <button
        type="submit"
        id={submitId}
        class="px-6 py-2 text-sm font-semibold text-white bg-blue-700 hover:bg-blue-800 rounded-md"
      >
        {submitIcon && <i class={submitIcon} />} {submitLabel}
      </button>
    </div>
  )}
</form>

<script define:vars={{ formId }}>
  function initSelect2InForm(formEl) {
    if (typeof jQuery === "undefined" || typeof jQuery.fn.select2 === "undefined") return;

    jQuery(formEl).find(".select2-field").each(function () {
      // Destroy existing instance before re-init to prevent double-binding
      if (jQuery(this).hasClass("select2-hidden-accessible")) {
        jQuery(this).select2("destroy");
      }
      jQuery(this).select2({
        placeholder: jQuery(this).data("placeholder") || "Semua",
        allowClear: true,
        width: "style",
        dropdownParent: jQuery(this).parent(),
      });
    });
  }

  function waitForSelect2(callback) {
    if (typeof jQuery !== "undefined" && typeof jQuery.fn.select2 !== "undefined") {
      callback();
    } else {
      setTimeout(() => waitForSelect2(callback), 100);
    }
  }

  function setup() {
    const form = document.getElementById(formId);
    if (!form) return;

    waitForSelect2(() => {
      initSelect2InForm(form);

      form.addEventListener("reset", function () {
        setTimeout(() => {
          jQuery(this).find(".select2-field").val(null).trigger("change");
        }, 10);
      });
    });
  }

  // Initial setup
  setup();

  // Astro view transitions — register once, cleanup after swap
  const handlePageLoad = () => setup();
  document.addEventListener("DOMContentLoaded", handlePageLoad);
  document.addEventListener(
    "DOMContentLoaded",
    () => document.removeEventListener("DOMContentLoaded", handlePageLoad),
    { once: true }
  );
</script>