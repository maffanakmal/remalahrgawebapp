---
// FilterForm.astro
// Requires: Select2Provider.astro loaded once in Layout.astro
import FormField from "./FormField.astro";

interface Props {
  formId: string;
  fields: any[];
  submitLabel?: string;
  orientation?: "horizontal" | "vertical";
  buttonPosition?: "right" | "bottom";
}

const {
  formId,
  fields,
  submitLabel = "Filter",
  orientation = "horizontal",
  buttonPosition = "right",
} = Astro.props;
---

<form
  id={formId}
  class="p-4 bg-white rounded-lg border border-gray-300 mb-5"
  autocomplete="off"
>
  <div
    class={`grid gap-4 items-end ${orientation === "vertical" ? "space-y-4" : ""}`}
    style={orientation === "horizontal"
      ? "grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));"
      : ""}
  >
    {fields.map((field) => (
      <FormField {...field} />
    ))}

    <div
      class={`flex flex-wrap items-end gap-3 ${
        buttonPosition === "bottom" || orientation === "vertical"
          ? "col-span-full"
          : ""
      }`}
    >
      <button
        type="submit"
        class="bg-blue-600 text-white text-sm font-medium px-5 py-2 rounded-md hover:bg-blue-700 transition-all flex items-center justify-center gap-2 w-full sm:w-auto"
      >
        <i class="fa-solid fa-filter"></i> {submitLabel}
      </button>

      <button
        type="reset"
        class="flex items-center gap-2 px-4 py-2 bg-gray-100 border border-gray-300 hover:bg-gray-200 rounded-md text-sm transition sm:w-auto w-full justify-center"
      >
        <i class="fa-solid fa-arrow-rotate-left"></i> Reset
      </button>
    </div>
  </div>
</form>

<script define:vars={{ formId }}>
  function initSelect2InForm(formEl) {
    if (typeof jQuery === "undefined" || typeof jQuery.fn.select2 === "undefined") return;

    jQuery(formEl).find(".select2-field").each(function () {
      // Destroy existing instance before re-init to prevent double-binding
      if (jQuery(this).hasClass("select2-hidden-accessible")) {
        jQuery(this).select2("destroy");
      }
      jQuery(this).select2({
        placeholder: jQuery(this).data("placeholder") || "Semua",
        allowClear: true,
        width: "100%",
      });
    });
  }

  function waitForSelect2(callback) {
    if (typeof jQuery !== "undefined" && typeof jQuery.fn.select2 !== "undefined") {
      callback();
    } else {
      setTimeout(() => waitForSelect2(callback), 100);
    }
  }

  function setup() {
    const form = document.getElementById(formId);
    if (!form) return;

    waitForSelect2(() => {
      initSelect2InForm(form);

      form.addEventListener("reset", function () {
        setTimeout(() => {
          jQuery(this).find(".select2-field").val(null).trigger("change");
        }, 10);
      });
    });
  }

  // Initial setup
  setup();

  // Astro view transitions — register once, cleanup after swap
  const handlePageLoad = () => setup();
  document.addEventListener("DOMContentLoaded", handlePageLoad);
  document.addEventListener(
    "DOMContentLoaded",
    () => document.removeEventListener("DOMContentLoaded", handlePageLoad),
    { once: true }
  );
</script>