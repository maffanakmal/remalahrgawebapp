---
// FormField.astro
// Unified field — replaces both FilterField.astro and FormField.astro

interface Option {
  label: string;
  value: string;
}

interface Props {
  label?: string;
  name: string;
  type?: string;
  placeholder?: string;
  icon?: string;
  required?: boolean;
  value?: string;
  options?: Option[];
  rows?: number;
  showStrength?: boolean;
  select2?: boolean;
  accept?: string;
  honeypot?: boolean;
}

const {
  label,
  name,
  type = "text",
  placeholder = "",
  icon,
  required = false,
  value = "",
  options = [],
  rows = 4,
  showStrength = false,
  select2 = false,
  accept,
  honeypot = false,
} = Astro.props;

const baseClass = [
  "w-full py-2 border border-gray-300 rounded-md",
  "focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent",
  "text-sm bg-white transition-all",
  icon && type !== "file" ? "pl-10" : "pl-3",
  type === "password" ? "pr-10" : "pr-3",
].join(" ");
---

{honeypot ? (
  <input type="text" name={name} class="hidden" tabindex="-1" autocomplete="off" />
) : (
  <div class="space-y-1.5" data-field-container>
    {label && (
      <label for={name} class="block text-sm font-medium text-gray-700">
        {label}
        {required && <span class="text-red-500 ml-0.5">*</span>}
      </label>
    )}

    <div class="relative">
      {icon && type !== "file" && (
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <i class={`${icon} text-gray-400 text-sm`}></i>
        </div>
      )}

      {type === "select" ? (
        <div class="relative">
          <select
            id={name}
            name={name}
            required={required}
            class={`${baseClass} appearance-none pr-8 ${select2 ? "select2-field" : ""}`}
            data-placeholder={placeholder || "Semua"}
          >
            <option value="">{placeholder || "Semua"}</option>
            {options.map((opt) => (
              <option value={opt.value} selected={value === opt.value}>
                {opt.label}
              </option>
            ))}
          </select>

          {!select2 && (
            <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
              <i class="fas fa-chevron-down text-gray-400 text-xs"></i>
            </div>
          )}
        </div>

      ) : type === "textarea" ? (
        <textarea
          id={name}
          name={name}
          rows={rows}
          required={required}
          placeholder={placeholder}
          class={`${baseClass} resize-none`}
        >{value}</textarea>

      ) : type === "file" ? (
        <div class="flex items-center justify-center w-full">
          <label
            for={name}
            class="flex flex-col items-center justify-center w-full h-32 border-2 border-gray-300 border-dashed rounded-lg cursor-pointer bg-gray-50 hover:bg-gray-100 transition-colors"
          >
            <div class="flex flex-col items-center justify-center pt-5 pb-6">
              <i class="fas fa-cloud-upload-alt text-gray-400 text-2xl mb-2"></i>
              <p class="mb-1 text-sm text-gray-500 font-semibold">
                Klik untuk upload{" "}
                <span class="font-normal text-gray-400">atau drag & drop</span>
              </p>
              <p
                id={`file-name-${name}`}
                class="text-xs text-blue-600 font-medium truncate max-w-[200px]"
              >
                {placeholder || "Maksimal 10MB"}
              </p>
            </div>
            <input
              id={name}
              name={name}
              type="file"
              class="hidden"
              accept={accept}
              required={required}
              onchange={`document.getElementById('file-name-${name}').innerText = this.files[0] ? this.files[0].name : '${placeholder || "Maksimal 10MB"}'`}
            />
          </label>
        </div>

      ) : (
        <input
          type={type}
          id={name}
          name={name}
          value={value}
          required={required}
          placeholder={placeholder}
          class={baseClass}
          data-strength={showStrength ? "true" : undefined}
        />
      )}

      {type === "password" && (
        <button
          type="button"
          class="absolute right-3 top-1/2 -translate-y-1/2 cursor-pointer text-gray-400 hover:text-gray-600"
          data-toggle-password={name}
          aria-label="Toggle password visibility"
        >
          <i class="fas fa-eye"></i>
        </button>
      )}
    </div>

    {showStrength && type === "password" && (
      <div class="mt-2 space-y-1">
        <div class="flex gap-1">
          {[1, 2, 3, 4].map(() => (
            <span class="pw-bar h-1 flex-1 bg-gray-200 rounded"></span>
          ))}
        </div>
        <p class="pw-text text-xs text-gray-500"></p>
      </div>
    )}

    <span data-error={name} class="text-xs text-red-500 hidden"></span>
  </div>
)}

<script>
  function initPasswordToggle() {
    const toggleButtons = document.querySelectorAll('[data-toggle-password]');

    toggleButtons.forEach((button) => {
      if (button.getAttribute('data-listener-attached') === 'true') return;

      button.addEventListener('click', () => {
        const inputName = button.getAttribute('data-toggle-password');
        const passwordInput = document.getElementById(inputName) as HTMLInputElement | null;
        const icon = button.querySelector('i');

        if (passwordInput && icon) {
          if (passwordInput.type === 'password') {
            passwordInput.type = 'text';
            icon.classList.remove('fa-eye');
            icon.classList.add('fa-eye-slash');
          } else {
            passwordInput.type = 'password';
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
          }
        }
      });

      button.setAttribute('data-listener-attached', 'true');
    });
  }

  initPasswordToggle();

  document.addEventListener('DOMContentLoaded', initPasswordToggle);
</script>