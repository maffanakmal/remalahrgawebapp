---
import { ROUTES } from "../../../constants/routes.js";

const currentPath = Astro.url.pathname;

const mainRoutes = Object.values(ROUTES).slice(4, 6);
---

<ul class="space-y-1 px-3 py-4">
  {
    mainRoutes.map((route) => {
      const childrenArray = route.children ? Object.values(route.children) : [];

      const isActive = route.children
        ? childrenArray.some((child) => currentPath.startsWith(child.path))
        : currentPath === route.path;

      return (
        <li>
          {route.children ? (
            <details open={isActive} class="group">
              <summary
                class:list={[
                  "flex items-center justify-between px-3 py-2 rounded-lg text-sm cursor-pointer transition-colors",
                  isActive
                    ? "text-blue-600 font-medium"
                    : "text-gray-600 hover:text-gray-900",
                ]}
              >
                <div class="flex items-center gap-3">
                  <i class:list={[route.icon, "w-4 text-center"]} />
                  <span>{route.name}</span>
                </div>

                <i class="fa-solid fa-chevron-down text-xs transition-transform group-open:rotate-180" />
              </summary>

              <ul class="ml-7 mt-2 space-y-1">
                {childrenArray.map((child) => (
                  <li>
                    <a
                      href={child.path}
                      class:list={[
                        "flex items-center gap-2 px-3 py-2 rounded-lg text-sm transition-colors",
                        currentPath.startsWith(child.path)
                          ? "text-blue-600 font-medium"
                          : "text-gray-600",
                      ]}
                    >
                      <i class:list={[child.icon, "w-4 text-center"]} />
                      <span>{child.name}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          ) : (
            <a
              href={route.path}
              class:list={[
                "flex items-center gap-3 px-3 py-2 rounded-lg text-sm transition-colors",
                isActive
                  ? "text-blue-600 font-medium"
                  : "text-gray-600 hover:text-gray-900",
              ]}
            >
              <i class:list={[route.icon, "w-4 text-center"]} />
              <span>{route.name}</span>
            </a>
          )}
        </li>
      );
    })
  }
</ul>