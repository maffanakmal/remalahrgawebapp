---
import DashboardLayout from "../../../../layouts/DashboardLayout.astro";
import AlertCard from "../../../../components/ui/AlertCard.astro";

import { ROUTES } from "../../../../constants/routes";
---

<DashboardLayout title="Inventory Kendaraan">
  <AlertCard />

  <div class="bg-white rounded-xl border border-gray-200">
    <div
      class="px-6 py-4 border-b border-gray-100 flex items-center justify-between"
    >
      <div class="flex items-center gap-3">
        <div
          class="w-8 h-8 bg-blue-50 rounded-lg flex items-center justify-center"
        >
          <i class="fas fa-car text-blue-600 text-sm"></i>
        </div>
        <div>
          <h2 class="text-sm font-semibold text-gray-800">Form GA Remala</h2>
          <p class="text-xs text-gray-500">Laporan Inventory Kendaraan</p>
        </div>
      </div>
      <div class="p-2 rounded-md hover:bg-gray-100 transition-all">
        <p class="text-center text-sm text-gray-600">
          <a
            href={ROUTES.Pengajuan.children.InventoryKendaraan.path}
            class="text-gray-600 hover:text-gray-700 font-semibold transition-all"
          >
            <i class="fa-solid fa-arrow-left"></i>
          </a>
        </p>
      </div>
    </div>

    <div class="p-6">
      <form id="vehicleInventoryForm" class="space-y-6" novalidate>
        <div>
          <h3
            class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4"
          >
            Informasi Laporan
          </h3>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label
                for="vehicle_inventory_date"
                class="block text-sm font-medium text-gray-700 mb-1.5"
              >
                Tanggal Inventory <span class="text-red-500">*</span>
              </label>
              <input
                type="date"
                id="vehicle_inventory_date"
                name="vehicle_inventory_date"
                required
                class="w-full py-2.5 px-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              />
            </div>

            <div>
              <label
                for="plate_number"
                class="block text-sm font-medium text-gray-700 mb-1.5"
              >
                Nomor Plat <span class="text-red-500">*</span>
              </label>
              <select
                id="plate_number"
                name="plate_number"
                required
                class="w-full py-2.5 px-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white text-gray-700"
              >
                <option value="">Pilih Nomor Plat</option>
              </select>
            </div>
          </div>
        </div>

        <div>
          <h3
            class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4"
          >
            Informasi Kendaraan
          </h3>

          <div
            id="emptyState"
            class="flex flex-col items-center justify-center py-10 text-center border-2 border-dashed border-gray-200 rounded-lg"
          >
            <div
              class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center mb-3"
            >
              <i class="fas fa-car text-gray-400"></i>
            </div>
            <p class="text-sm text-gray-500 font-medium">
              Belum ada kendaraan dipilih
            </p>
            <p class="text-xs text-gray-400 mt-1">
              Pilih nomor plat untuk melihat informasi kendaraan
            </p>
          </div>

          <div class="vehicle-information hidden">
            
          </div>
        </div>

        <hr class="border-gray-100" />

        <div>
          <h3
            class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4"
          >
            Kondisi Kendaraan
          </h3>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label
                for="vehicle_color"
                class="block text-sm font-medium text-gray-700 mb-1.5"
              >
                Warna Kendaraan <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="vehicle_color"
                name="vehicle_color"
                placeholder="Contoh: Putih"
                required
                class="w-full py-2.5 px-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              />
            </div>

            <div>
              <label
                for="vehicle_milage"
                class="block text-sm font-medium text-gray-700 mb-1.5"
              >
                KM Kendaraan <span class="text-red-500">*</span>
              </label>
              <div class="relative">
                <input
                  type="number"
                  id="vehicle_milage"
                  name="vehicle_milage"
                  required
                  min="0"
                  placeholder="Contoh: 15000"
                  class="w-full py-2.5 px-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent pr-12"
                />
                <span
                  class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-gray-400 font-medium"
                >
                  KM
                </span>
              </div>
            </div>

            <div class="md:col-span-2">
              <label
                for="equipment_detail"
                class="block text-sm font-medium text-gray-700 mb-1.5"
              >
                Detail Peralatan <span class="text-red-500">*</span>
              </label>
              <textarea
                id="equipment_detail"
                name="equipment_detail"
                placeholder="Contoh: Ban cadangan, dongkrak, segitiga pengaman..."
                required
                rows="3"
                class="w-full py-2.5 px-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none"
              ></textarea>
            </div>

            <div class="md:col-span-2">
              <label
                for="physical_condition"
                class="block text-sm font-medium text-gray-700 mb-1.5"
              >
                Kondisi Fisik <span class="text-red-500">*</span>
              </label>
              <textarea
                id="physical_condition"
                name="physical_condition"
                placeholder="Contoh: Bodi mulus, kaca tidak retak, lampu berfungsi normal..."
                required
                rows="3"
                class="w-full py-2.5 px-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none"
              ></textarea>
            </div>
          </div>
        </div>

        <div id="feedback" class="hidden text-sm p-3 border rounded-lg"></div>

        <hr class="border-gray-100" />

        <div class="flex items-center justify-end gap-3">
          <div class="flex items-center gap-3">
            <button
              id="resetBtn"
              class="flex items-center gap-2 px-5 py-2 bg-gray-600 text-white text-sm font-medium rounded-lg hover:bg-gray-700 transition-all disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Reset
            </button>
            <button
              type="submit"
              id="submitBtn"
              class="flex items-center gap-2 px-5 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-all disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Kirim
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>
</DashboardLayout>

<script>
  import "../../../../scripts/global.js";
  import "../../../../scripts/inventorykendaraan/form.js";
</script>
