---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import { ROUTES } from "../../../constants/routes";

const headers = [
  "Tgl Report",
  "Petugas",
  "Plat Nomor",
  "KM Kendaraan",
  "Aksi"
];
---

<DashboardLayout title="Daftar Inventory Kendaraan">
  <div class="bg-white border border-gray-300 rounded-xl p-6 w-full">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-lg font-semibold text-gray-900">Daftar Inventory Kendaraan</h1>
      <div>
        <a
          href={ROUTES.FormPengajuan.children.InventoryKendaraanCreate.path}
          class="inline-flex items-center gap-2 px-4 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 shadow-sm transition-all"
        >
          <i class="fas fa-plus text-xs"></i>
          <span>Tambah</span>
        </a>
      </div>
    </div>
      
    <div id="tableLoading" class="py-12 flex flex-col items-center justify-center text-center">
      <div class="w-8 h-8 border-4 border-blue-600 border-t-transparent rounded-full animate-spin mb-3"></div>
      <p class="text-sm text-gray-500 font-medium">Memuat data...</p>
    </div>

    <div id="tableContainer" class="hidden w-full">
      <table id="datatableInventoryKendaraan" class="w-full text-sm text-left text-gray-700">
        <thead class="bg-gray-50 text-xs uppercase text-gray-400 font-semibold tracking-wider border-b border-gray-100">
          <tr>
            {headers.map((h) => <th class="px-6 py-3">{h}</th>)}
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          </tbody>
      </table>
    </div>
  </div>
</DashboardLayout>

<script>
  import "../../../scripts/inventorykendaraan/list.js";
</script>