---
import DashboardLayout from "../../../../layouts/DashboardLayout.astro";
import AlertCard from "../../../../components/ui/AlertCard.astro";

import { ROUTES } from "../../../../constants/routes";

const locations = [
  { location_id: 1, location_name: "Jakarta - HQ" },
  { location_id: 2, location_name: "Bandung - Divisi IT" },
  { location_id: 3, location_name: "Surabaya - Divisi Finance" },
];
---

<DashboardLayout title="Belanja Bulanan">
  <AlertCard />

  <div class="bg-white rounded-xl border border-gray-200">
    <div
      class="px-6 py-4 border-b border-gray-100 flex items-center justify-between"
    >
      <div class="flex items-center gap-3">
        <div
          class="w-8 h-8 bg-blue-50 rounded-lg flex items-center justify-center"
        >
          <i class="fas fa-shopping-cart text-blue-600 text-sm"></i>
        </div>
        <div>
          <h2 class="text-sm font-semibold text-gray-800">Form GA Remala</h2>
          <p class="text-xs text-gray-500">Permintaan Belanja Bulanan</p>
        </div>
      </div>
      <div class="p-2 rounded-md hover:bg-gray-100 transition-all">
        <p class="text-center text-sm text-gray-600">
          <a
            href={ROUTES.Pengajuan.children.BelanjaBulanan.path}
            class="text-gray-600 hover:text-gray-700 font-semibold transition-all"
          >
            <i class="fa-solid fa-arrow-left"></i>
          </a>
        </p>
      </div>
    </div>

    <div class="p-6">
      <form id="monthlyShoppingForm" class="space-y-6" novalidate>
        <div>
          <h3
            class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4"
          >
            Informasi Pengajuan
          </h3>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="md:col-span-2">
              <label
                for="location"
                class="block text-sm font-medium text-gray-700 mb-1.5"
              >
                Perusahaan - Lokasi/Divisi
                <span class="text-red-500 ml-0.5">*</span>
              </label>
              <select
                id="location"
                name="location"
                required
                class="w-full py-2.5 px-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white text-gray-700"
              >
                <option value="">Pilih Perusahaan - Lokasi/Divisi</option>
              </select>
            </div>
          </div>
        </div>

        <hr class="border-gray-100" />

        <div>
          <div class="flex items-center justify-between mb-4">
            <div>
              <h3
                class="text-xs font-semibold text-gray-400 uppercase tracking-wider"
              >
                Daftar Item
              </h3>
              <p class="text-xs text-gray-400 mt-0.5">
                Tambahkan item yang ingin dibeli
              </p>
            </div>
            <button
              type="button"
              id="addItemBtn"
              disabled
              aria-label="Tambah item"
              class="flex items-center gap-2 bg-blue-600 text-white px-4 py-3 rounded-lg text-sm hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed transition-all"
            >
              <i class="fa-solid fa-plus text-xs" aria-hidden="true"></i>
            </button>
          </div>

          <div
            id="emptyState"
            class="flex flex-col items-center justify-center py-10 text-center border-2 border-dashed border-gray-200 rounded-lg"
          >
            <div
              class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center mb-3"
            >
              <i class="fas fa-box-open text-gray-400"></i>
            </div>
            <p class="text-sm text-gray-500 font-medium">Belum ada item</p>
            <p class="text-xs text-gray-400 mt-1">
              Klik "Tambah Item" untuk mulai mengisi
            </p>
          </div>

          <div id="itemContainer" class="space-y-3" data-products="[]" aria-live="polite"></div>
        </div>

        <div id="feedback" class="hidden text-sm p-3 border rounded-lg"></div>

        <hr class="border-gray-100" />

        <div class="flex items-center justify-end gap-3">
          <div class="flex items-center gap-3">
            <button
              id="resetBtn"
              class="flex items-center gap-2 px-5 py-2 bg-gray-600 text-white text-sm font-medium rounded-lg hover:bg-gray-700 transition-all disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Reset
            </button>
            <button
              type="submit"
              id="submitBtn"
              class="flex items-center gap-2 px-5 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-all disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Kirim
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>
</DashboardLayout>

<script>
  import "../../../../scripts/global.js";
  // import "../../scripts/belanjabulanan/form.js";
</script>

<!-- Populate location select -->
<script define:vars={{ locations }}>
  window.__locations__ = locations;
</script>

<script>
  import { initItemManager } from "../../../../utils/itemManager.js";

  // --- Dummy products per location ---
  const productsByLocation = {
    1: [
      {
        stock_id: 1,
        product_name: "Kertas A4",
        current_stock: 50,
        unit: "Rim",
      },
      { stock_id: 2, product_name: "Pulpen", current_stock: 100, unit: "Pcs" },
      { stock_id: 3, product_name: "Stapler", current_stock: 0, unit: "Pcs" },
    ],
    2: [
      { stock_id: 4, product_name: "Mouse", current_stock: 10, unit: "Pcs" },
      { stock_id: 5, product_name: "Keyboard", current_stock: 5, unit: "Pcs" },
      {
        stock_id: 6,
        product_name: "HDMI Cable",
        current_stock: 0,
        unit: "Pcs",
      },
    ],
    3: [
      {
        stock_id: 7,
        product_name: "Map Ordner",
        current_stock: 30,
        unit: "Pcs",
      },
      {
        stock_id: 8,
        product_name: "Tinta Printer",
        current_stock: 8,
        unit: "Botol",
      },
      { stock_id: 9, product_name: "Amplop", current_stock: 200, unit: "Pcs" },
    ],
  };

  // --- Populate location select ---
  const locationSelect = document.getElementById("location");

  window.__locations__.forEach((loc) => {
    const option = document.createElement("option");
    option.value = loc.location_id;
    option.textContent = loc.location_name;
    locationSelect.appendChild(option);
  });

  // --- Init item manager ---
  const containerEl = document.getElementById("itemContainer");

  const manager = initItemManager({
    containerEl,
    emptyStateEl: document.getElementById("emptyState"),
    addBtnEl: document.getElementById("addItemBtn"),
    products: [],
    maxItems: 5,
  });

  // --- Location change ---
  locationSelect.addEventListener("change", () => {
    const locationId = locationSelect.value;

    if (!locationId) {
      manager.clearItems();
      manager.setProducts([]);
      document.getElementById("addItemBtn").disabled = true;
      return;
    }

    const products = productsByLocation[locationId] || [];
    manager.clearItems();
    manager.setProducts(products);
    document.getElementById("addItemBtn").disabled = false;
  });
</script>
