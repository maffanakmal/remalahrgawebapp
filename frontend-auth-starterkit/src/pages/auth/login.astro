---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DynamicForm from "../../components/forms/DynamicForm.astro";
import AlertCard from "../../components/ui/AlertCard.astro";
import { ROUTES } from "../../constants/routes.js";

const loginFields = [
  {
    name: "email",
    label: "Email",
    type: "email",
    icon: "",
    placeholder: "Masukkan email Anda",
    required: true,
  },
  {
    name: "password",
    label: "Password",
    type: "password",
    icon: "",
    placeholder: "••••••••",
    required: true,
  },
  { name: "_hp", honeypot: true },
];
---

<BaseLayout>
  <AlertCard />
  <div
    class="w-full max-w-[560px] bg-white rounded-md shadow-md border border-gray-300 p-8 md:p-12"
  >
    <div class="mb-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-2 text-center">
        Selamat datang!
      </h2>
      <p class="text-gray-600 text-center">
        Silakan masuk ke akun Anda untuk melanjutkan.
      </p>
    </div>

    <DynamicForm
      formId="loginForm"
      submitId="loginBtn"
      fields={loginFields}
      submitLabel="Masuk"
    />

    <div class="mt-6 space-y-3">
      <div class="pt-3 border-t border-gray-200">
        <p class="text-center text-sm text-gray-600">
          Tidak punya akun?
          <a
            href={ROUTES.Register.path}
            class="text-blue-600 hover:text-blue-700 font-semibold transition-all"
          >
            Daftar
          </a>
        </p>
        <p class="text-center mt-3 text-sm text-gray-600">
          <a
            href={ROUTES.Home.path}
            class="text-gray-600 hover:text-gray-700 font-semibold transition-all"
          >
            Kembali
          </a>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import "../../scripts/auth/login.js";
</script>