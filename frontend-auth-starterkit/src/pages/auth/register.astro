---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DynamicForm from "../../components/forms/DynamicForm.astro";
import AlertCard from "../../components/ui/AlertCard.astro";
import { ROUTES } from "../../constants/routes.js";

const registerFields = [
  {
    name: "username",
    label: "Username",
    type: "text",
    icon: "",
    placeholder: "Masukkan username Anda",
    required: true,
  },
  {
    name: "email",
    label: "Email",
    type: "email",
    icon: "",
    placeholder: "Masukkan email Anda",
    required: true,
  },
  {
    name: "password",
    label: "Password",
    type: "password",
    icon: "",
    placeholder: "••••••••",
    required: true,
  },
  {
    name: "confirmPassword",
    label: "Konfirmasi Password",
    type: "password",
    icon: "",
    placeholder: "••••••••",
    required: true,
  },
  { name: "_hp", honeypot: true },
];
---

<BaseLayout>
  <AlertCard />
  <div
    class="w-full max-w-[560px] bg-white rounded-md shadow-md border border-gray-300 p-8 md:p-12"
  >
    <div class="mb-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-2 text-center">
        Selamat datang!
      </h2>
      <p class="text-gray-600 text-center">
        Silakan daftar untuk membuat akun baru.
      </p>
    </div>

    <DynamicForm
      formId="registerForm"
      submitId="registerBtn"
      fields={registerFields}
      submitLabel="Daftar"
    />

    <div class="mt-6 space-y-3">
      <div class="pt-3 border-t border-gray-200">
        <p class="text-center text-sm text-gray-600">
          Sudah punya akun?
          <a
            href={ROUTES.Login.path}
            class="text-blue-600 hover:text-blue-700 font-semibold transition-all"
          >
            Masuk
          </a>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import "../../scripts/auth/register.js";
</script>
