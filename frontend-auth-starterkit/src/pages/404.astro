---
import BaseLayout from "../layouts/BaseLayout.astro";
import { ROUTES } from "../constants/routes.js";
---

<BaseLayout>
  <div class="min-h-screen bg-slate-50 flex flex-col items-center justify-center p-6">
    
    <div class="text-center mb-10 max-w-md">
      <h1 class="text-2xl font-bold text-slate-800 tracking-tight sm:text-3xl">
        404 Not Found
      </h1>
      <p class="text-slate-500 text-md mt-2">
        Maaf, halaman yang Anda cari tidak ditemukan.
      </p>
    </div>

    <a
      href={ROUTES.Home.path}
      class="mt-6 px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors duration-300"
    >
      Kembali ke Beranda
  </a>
  </div>
</BaseLayout>
